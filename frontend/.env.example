# Public origin — canonical URLs, OG tags, sitemap. No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Strapi origin, used server-side only.
STRAPI_URL=http://127.0.0.1:1337

# Read-only Strapi API token (create in Strapi admin → Settings → API Tokens).
# SERVER ONLY. Never rename this to NEXT_PUBLIC_* — that ships it to the browser.
STRAPI_API_TOKEN=

# Create-only token used by the contact form Server Action to write an `enquiry`.
STRAPI_ENQUIRY_TOKEN=

# robots.txt kill-switch. Anything other than "true" ⇒ Disallow: / for every user-agent,
# so staging can never be indexed. Set to "true" in production only.
ALLOW_INDEXING=false

# Shared secret for the Strapi → Next ISR webhook (POST /api/revalidate).
REVALIDATE_SECRET=

# Contact form notification email.
ENQUIRY_NOTIFY_TO=
ENQUIRY_NOTIFY_FROM=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
