HOST=0.0.0.0
PORT=1337

# Secrets — generate fresh per environment. Never reuse dev values in production.
#   node -e "console.log(require('crypto').randomBytes(16).toString('base64'))"
APP_KEYS="toBeModified1,toBeModified2"
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified
ENCRYPTION_KEY=tobemodified

# Database — Postgres in dev and prod.
# Dev:  docker compose up -d  → host port 5433 (avoids clashing with a native Postgres on 5432)
# Prod: Postgres on the VPS, typically 127.0.0.1:5432
DATABASE_CLIENT=postgres
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5433
DATABASE_NAME=forbes_water
DATABASE_USERNAME=forbes
DATABASE_PASSWORD=
DATABASE_SSL=false

# Strapi → Next ISR webhook. Must match the frontend's REVALIDATE_SECRET.
FRONTEND_REVALIDATE_URL=http://127.0.0.1:3000/api/revalidate
REVALIDATE_SECRET=
