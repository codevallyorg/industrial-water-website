{
  "collectionName": "components_shared_seos",
  "info": { "displayName": "SEO", "icon": "search", "description": "Per-page SEO. Unset fields fall back to Global > Default SEO." },
  "options": {},
  "attributes": {
    "metaTitle": { "type": "string", "required": true, "maxLength": 70 },
    "metaDescription": { "type": "text", "required": true, "maxLength": 200 },
    "keywords": { "type": "string" },
    "ogImage": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
    "canonicalPath": { "type": "string", "description": "Override only. Defaults to the page route." },
    "noIndex": { "type": "boolean", "default": false }
  }
}
