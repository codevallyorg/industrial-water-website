{
  "kind": "collectionType",
  "collectionName": "enquiries",
  "info": {
    "singularName": "enquiry",
    "pluralName": "enquiries",
    "displayName": "Enquiry",
    "description": "Contact form submissions. PERSONAL DATA: never publicly readable, never populated into a page query, create-only via the form token."
  },
  "options": { "draftAndPublish": false },
  "pluginOptions": {},
  "attributes": {
    "name": { "type": "string", "required": true },
    "email": { "type": "email", "required": true },
    "phone": { "type": "string" },
    "industry": { "type": "string" },
    "message": { "type": "text", "required": true },
    "status": {
      "type": "enumeration",
      "enum": ["new", "in-progress", "responded", "spam"],
      "default": "new"
    }
  }
}
